{
  "entities": {
    "User": {
      "title": "User",
      "description": "User preferences and goals",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "goals": {
          "type": "object",
          "properties": {
            "calories": { "type": "number" },
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fat": { "type": "number" },
            "waterMl": { "type": "number" },
            "targetWeightKg": { "type": "number" },
            "dietType": { "type": "string" },
            "mealCount": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "CustomProduct": {
      "title": "CustomProduct",
      "description": "Custom food product defined by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "caloriesPer100g": { "type": "number" },
        "proteinPer100g": { "type": "number" },
        "carbsPer100g": { "type": "number" },
        "fatPer100g": { "type": "number" },
        "isCustom": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "barcode": { "type": "string" }
      },
      "required": ["id", "name", "caloriesPer100g", "proteinPer100g", "carbsPer100g", "fatPer100g"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Custom meal recipe with custom ingredients list",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ingredients": { "type": "array" },
        "totalWeightGrams": { "type": "number" },
        "totalCalories": { "type": "number" },
        "totalProtein": { "type": "number" },
        "totalCarbs": { "type": "number" },
        "totalFat": { "type": "number" }
      },
      "required": ["id", "name", "ingredients", "totalWeightGrams"]
    },
    "DayLog": {
      "title": "DayLog",
      "description": "Logged dynamic meals, water, weight log values",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "meals": { "type": "array" },
        "waterIntakeMl": { "type": "number" },
        "weightKg": { "type": "number" },
        "medsTaken": { "type": "object" }
      },
      "required": ["date", "waterIntakeMl"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles with synchronization settings and core dietary goals"
    },
    "users/{userId}/customProducts/{productId}": {
      "schema": "CustomProduct",
      "description": "Subcollection storing user-created custom food products"
    },
    "users/{userId}/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Subcollection storing user-created custom cooking recipes"
    },
    "users/{userId}/dayLogs/{date}": {
      "schema": "DayLog",
      "description": "Subcollection storing logged values per specific YYYY-MM-DD date"
    }
  }
}
